    <CheatEntry>
      <ID>6</ID>
      <Description>"拦截脚本"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
//code from here to '[DISABLE]' will be used to enable the cheat
alloc(newmem,2048,SharedCodeSnippet:HurtBtnCallBack+14) 
label(returnhere)
label(originalcode)
label(exit)
alloc(pPlayer, 8)     // 1. 申请 8 个字节的内存，用来当做存放地址的“安全口袋”
registerSymbol(pPlayer) // 2. 把这个口袋命名为 pPlayer，让其他脚本也能认得它

newmem: //this is allocated memory, you have read,write,execute access
//place your code here
  mov [pPlayer], rsi  // 3. 核心：趁游戏不注意，把 rsi 里的玩家地址复制一份放到我们的口袋里

originalcode:
mov [rsi+18],eax
mov rsi,[rsp]

exit:
jmp returnhere

SharedCodeSnippet:HurtBtnCallBack+14:
jmp newmem
nop 2
returnhere:



 
 
[DISABLE]
//code from here till the end of the code will be used to disable the cheat
dealloc(newmem)
SharedCodeSnippet:HurtBtnCallBack+14:
db 89 46 18 48 8B 34 24
//mov [rsi+18],eax
//mov rsi,[rsp]
</AssemblerScript>
    </CheatEntry>
    <CheatEntry>
      <ID>5</ID>
      <Description>"自动汇编脚本"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]

{$lua}
-- 1. 查找 Hurt 函数
local method = mono_findMethod('', 'Player', 'Hurt')

-- 2. 注册给汇编
registerSymbol("Hurt_Address", method)
{$asm}

alloc(newmem, 2048)
createThread(newmem) // 创建一个新线程来主动执行这段代码

newmem:
  // 2. 模拟调用环境
  // 假设你的玩家实例地址保存在一个叫 pPlayer 的全局指针里
  // 汇编中，通常 rcx(x64) 或 ecx(x86) 存放实例指针 (this)
  mov rcx, [pPlayer]
  // rdx 存放第一个参数（比如加 1000 金币）
  mov rdx, #1

  // 3. 直接 call 该函数
  call Hurt_Address

  // 执行完记得返回，结束线程
  ret

[DISABLE]
unregisterSymbol(Hurt_Address)
dealloc(newmem)

</AssemblerScript>
    </CheatEntry>
